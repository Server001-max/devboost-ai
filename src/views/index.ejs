<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <div class="container">
    <header class="header">
      <div class="logo">🚀 DevBoost AI</div>
      <nav class="nav">
        <a href="/">Home</a>
        <a href="/dashboard">Dashboard</a>
        <a href="/playground">Playground</a>
        <a href="https://github.com/yourusername/devboost-ai" target="_blank">GitHub</a>
      </nav>
    </header>

    <section class="hero">
      <h1>AI-Powered Developer Toolkit</h1>
      <p>Optimize code, generate tests, fix security issues, and more - all with AI</p>
      <div>
        <a href="/playground" class="btn btn-primary">Try Now</a>
        <a href="https://github.com/yourusername/devboost-ai" class="btn btn-secondary">★ Star on GitHub</a>
      </div>
    </section>

    <section class="stats">
      <div class="stat-box">
        <div class="stat-number">20+</div>
        <div>Languages Supported</div>
      </div>
      <div class="stat-box">
        <div class="stat-number">100%</div>
        <div>Free & Open Source</div>
      </div>
      <div class="stat-box">
        <div class="stat-number">∞</div>
        <div>No Limits</div>
      </div>
    </section>

    <section class="features">
      <div class="feature-card">
        <div class="feature-icon">⚡</div>
        <h3>Code Optimization</h3>
        <p>Automatically optimize your code for better performance</p>
      </div>
      <div class="feature-card">
        <div class="feature-icon">🛡️</div>
        <h3>Security Scanner</h3>
        <p>Find and fix security vulnerabilities instantly</p>
      </div>
      <div class="feature-card">
        <div class="feature-icon">📝</div>
        <h3>Documentation Generator</h3>
        <p>Generate professional documentation automatically</p>
      </div>
      <div class="feature-card">
        <div class="feature-icon">🧪</div>
        <h3>Test Generator</h3>
        <p>Create unit tests with zero effort</p>
      </div>
      <div class="feature-card">
        <div class="feature-icon">🌍</div>
        <h3>Code Translator</h3>
        <p>Translate code between different languages</p>
      </div>
      <div class="feature-card">
        <div class="feature-icon">💡</div>
        <h3>AI Assistant</h3>
        <p>Get coding help from our AI</p>
      </div>
    </section>

    <footer style="text-align: center; padding: 40px 0; opacity: 0.7;">
      <p>Made with ❤️ | Open Source | MIT License</p>
      <p>⭐ Star us on GitHub ⭐</p>
    </footer>
  </div>

  <script src="/js/app.js"></script>
</body>
</html>
